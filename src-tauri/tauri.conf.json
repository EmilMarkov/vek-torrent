{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VEK Torrent",
  "version": "1.0.0",
  "identifier": "dev.vek.torrent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VEK Torrent",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 620,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "vektorrent"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxRUQ0NzM0OTkyQThCMTYKUldRV2l5cVpORWZ0WVNIUDBNN3Z5MkZaeWdyZmpBdm9ZT21WRVYzb2IvbkdlMzhoZllwOEdzNDEK",
      "endpoints": [
        "https://github.com/EmilMarkov/vek-torrent/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Поиск по rutracker и встроенный менеджер загрузок",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}
